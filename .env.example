# Never put real keys in git. Copy to .env locally.
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8011
API_PUBLIC_BASE_URL=http://127.0.0.1:8011
WEB_PORT=3847

DATABASE_URL=postgresql://learnforge:learnforge@localhost:5432/learnforge
REDIS_URL=redis://localhost:6379/0

MODEL_PROVIDER=gemini
GEMINI_API_KEY=replace_with_local_gemini_key
GEMINI_TEXT_MODEL=gemini-3.1-pro-preview
GEMINI_TEXT_FALLBACK_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3-pro-image
GEMINI_IMAGE_FALLBACK_MODEL=gemini-3-pro-image-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# Optional legacy image2 compatibility. Gemini Image is the default image path.
# IMAGE2_API_KEY=replace_with_local_key
# IMAGE2_BASE_URL=replace_with_image2_base_url
# IMAGE2_MODEL=gpt-image-2

HERMES_MODE=real
HERMES_PROVIDER=gemini
HERMES_HOME=.runtime/hermes
HERMES_REQUIRE_SDK=true
PYTHON_VISION_FALLBACK_ENABLED=false
# Optional when hermes-agent is not installed in the API venv:
# HERMES_SDK_PATH=/absolute/path/to/hermes-agent
# HERMES_SDK_SITE_PACKAGES=/absolute/path/to/hermes/site-packages

# S3-compatible artifact/object storage. Production must configure these.
OBJECT_STORAGE_ENDPOINT=https://replace-with-s3-compatible-endpoint
OBJECT_STORAGE_BUCKET=learnforge-artifacts
OBJECT_STORAGE_ACCESS_KEY_ID=replace_with_access_key_id
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace_with_secret_access_key
OBJECT_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com/learnforge-artifacts
OBJECT_STORAGE_REGION=auto

MEMORY_PROVIDER=edumem0
VECTOR_STORE=pgvector

# NotebookLM line: Open Notebook runs as a source/search/transformation sidecar.
# All user-visible answers still flow through the LearnForge Hermes chat.
NOTEBOOKLM_PROVIDER=open_notebook
OPEN_NOTEBOOK_WEB_URL=http://localhost:8502
OPEN_NOTEBOOK_API_URL=http://localhost:5055
OPEN_NOTEBOOK_ALLOWED_ORIGIN=http://localhost:8502
OPEN_NOTEBOOK_TIMEOUT_SECONDS=8
OPEN_NOTEBOOK_PASSWORD=
OPEN_NOTEBOOK_ENCRYPTION_KEY=learnforgeopennotebooksecret0000

# English workspace sidecar. The service source is vendored under
# services/english-word-fission and is started by scripts/dev.sh.
EFW_BASE_URL=http://localhost:3011
EFW_DATABASE_URL=postgresql://learnforge:learnforge@localhost:5432/learnforge?schema=LPT_english
